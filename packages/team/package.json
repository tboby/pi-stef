{
  "name": "@pi-stef/team",
  "version": "0.3.3",
  "description": "Pi extension that runs a steerable team of role-agents for plan/review/implement workflows, including strategy-aware lanes, resume, and optional tmux panes.",
  "type": "module",
  "license": "MIT",
  "files": [
    "src/",
    "extensions/",
    "bin/"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "team",
    "team-of-agents",
    "steering",
    "planner",
    "reviewer",
    "developer"
  ],
  "scripts": {
    "test": "vitest run --test-timeout=60000",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@pi-stef/agent-workflows": "^0.3.0",
    "@pi-stef/atlassian": "^0.3.0",
    "@pi-stef/catalog": "^0.3.0",
    "@pi-stef/figma": "^0.3.0",
    "@pi-stef/paths": "^0.3.0",
    "@pi-stef/team": "^0.3.0",
    "@pi-stef/web": "^0.3.0",
    "@sinclair/typebox": "*",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  }
}
