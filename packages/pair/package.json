{
  "name": "@pi-stef/pair",
  "version": "0.2.1",
  "description": "Pi extension for plan/review/implement workflows using pi-subagents for reviewer spawning.",
  "type": "module",
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "companions": [
      "git:github.com/obra/superpowers"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@tintinweb/pi-subagents": "*"
  },
  "dependencies": {
    "@pi-stef/paths": "workspace:*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "typescript": "*",
    "vitest": "*"
  },
  "files": [
    "src/",
    "extensions/",
    "skills/",
    "templates/",
    "agents/"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pair",
    "plan",
    "implement",
    "review"
  ],
  "license": "MIT"
}
