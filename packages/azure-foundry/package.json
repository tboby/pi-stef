{
  "name": "@pi-stef/azure-foundry",
  "version": "0.1.1",
  "description": "Azure Foundry and Azure OpenAI deployments as native Pi providers — config-driven, JSONC support, validation",
  "type": "module",
  "license": "MIT",
  "files": [
    "src/",
    "extensions/",
    "scripts/",
    "config.schema.json"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:schema": "node scripts/emit-schema.mjs",
    "verify": "node scripts/verify.mjs"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "azure",
    "azure-foundry",
    "azure-openai",
    "provider"
  ],
  "dependencies": {
    "@pi-stef/catalog": "^0.3.0",
    "@pi-stef/team": "^0.3.0",
    "@pi-stef/web": "^0.3.0",
    "@pi-stef/figma": "^0.3.0",
    "@pi-stef/atlassian": "^0.3.0",
    "@pi-stef/superpowers-adapter": "^0.3.0",
    "@pi-stef/paths": "^0.3.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  }
}
