{
  "name": "@pi-stef/web",
  "version": "0.2.0",
  "private": true,
  "description": "Pi extension for no-key web search, URL fetch, rendered scraping, browser sessions, login flows, and CloakBrowser-backed page access.",
  "type": "module",
  "license": "MIT",
  "files": ["src/", "extensions/", "bin/"],
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "web",
    "web-search",
    "web-fetch",
    "cloakbrowser",
    "browser-automation"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check-runtime": "node bin/check-runtime.mjs",
    "install-browser": "npx cloakbrowser install"
  },
  "dependencies": {
    "@pi-stef/paths": "file:../paths",
    "@mozilla/readability": "^0.6.0",
    "cloakbrowser": "^0.3.31",
    "defuddle": "^0.18.1",
    "jsdom": "^29.1.0",
    "playwright-core": "^1.59.1",
    "turndown": "^7.2.4",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/turndown": "5.0.6"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  }
}
