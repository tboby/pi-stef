{
  "name": "@pi-stef/figma",
  "version": "0.2.0",
  "private": true,
  "description": "Pi extension for Figma REST API tools, compact design context, and Jira-linked Figma summaries.",
  "type": "module",
  "license": "MIT",
  "files": ["src/", "extensions/"],
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": ["pi-package", "pi-extension", "figma"],
  "dependencies": {
    "@pi-stef/paths": "file:../paths",
    "zod": "^3.25.62"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "pi": {
    "extensions": ["./extensions"]
  }
}
