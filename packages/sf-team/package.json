{
  "name": "@pi-stef/sf-team",
  "version": "0.1.0",
  "private": true,
  "description": "Pi extension that runs a steerable team of role-agents for plan/review/implement workflows, including strategy-aware lanes, resume, and optional tmux panes.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "sf-team",
    "team-of-agents",
    "steering",
    "planner",
    "reviewer",
    "developer"
  ],
  "scripts": {
    "test": "vitest run --test-timeout=60000",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@pi-stef/agent-workflows": "file:../agent-workflows",
    "@pi-stef/atlassian": "file:../atlassian",
    "@pi-stef/figma": "file:../figma",
    "@pi-stef/web": "file:../web",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "@sinclair/typebox": "*"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  }
}
