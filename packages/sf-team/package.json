{
  "name": "@life-of-pi/fh-team",
  "version": "0.1.0",
  "private": true,
  "description": "Pi extension that runs a steerable team of role-agents for plan/review/implement workflows, including strategy-aware lanes, resume, and optional tmux panes.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "fh-team",
    "team-of-agents",
    "steering",
    "planner",
    "reviewer",
    "developer"
  ],
  "scripts": {
    "test": "vitest run --test-timeout=60000",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@life-of-pi/agent-workflows": "file:../agent-workflows",
    "@life-of-pi/atlassian": "file:../atlassian",
    "@life-of-pi/figma": "file:../figma",
    "@life-of-pi/web-access": "file:../web-access",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "typebox": "^1.1.35"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  }
}
