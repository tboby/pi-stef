{
  "name": "@pi-stef/atlassian",
  "version": "0.2.2",
  "description": "Pi extension and CLI for verified Atlassian Jira and Confluence tools.",
  "type": "module",
  "license": "MIT",
  "files": [
    "src/",
    "extensions/",
    "bin/"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "atlassian",
    "jira",
    "confluence"
  ],
  "dependencies": {
    "@pi-stef/paths": "file:../paths",
    "@pi-stef/figma": "file:../figma",
    "@sinclair/typebox": "*",
    "zod": "^3.25.62"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  }
}
