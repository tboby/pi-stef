{
  "name": "pi-stef",
  "version": "0.1.0",
  "private": true,
  "description": "Custom package collection for the pi coding agent.",
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "release": "node scripts/release.mjs",
    "docs:dev": "vitepress dev docs-site",
    "docs:build": "vitepress build docs-site",
    "docs:preview": "vitepress preview docs-site"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.3",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@pi-stef/agent-workflows": "^0.3.0",
    "@pi-stef/atlassian": "^0.3.0",
    "@pi-stef/catalog": "^0.3.0",
    "@pi-stef/figma": "^0.3.0",
    "@pi-stef/paths": "^0.3.0",
    "@pi-stef/team": "^0.3.0",
    "@pi-stef/web": "^0.3.0"
  }
}
